{
  "name": "metabase-cli",
  "version": "0.3.0",
  "type": "module",
  "description": "Headless CLI interface for Metabase instances",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "metabase-cli": "./dist/metabase.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ bin/ test/",
    "lint:fix": "eslint src/ bin/ test/ --fix",
    "format": "prettier --write src/ bin/ test/",
    "format:check": "prettier --check src/ bin/ test/",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "metabase",
    "cli",
    "analytics",
    "sql",
    "dashboard"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rohanraarora/metabase-cli.git"
  },
  "author": "Rohan Arora",
  "license": "MIT",
  "homepage": "https://github.com/rohanraarora/metabase-cli#readme",
  "bugs": {
    "url": "https://github.com/rohanraarora/metabase-cli/issues"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.14.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^2.0.0"
  }
}
